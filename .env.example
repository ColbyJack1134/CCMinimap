# Copy to `.env` and fill in. docker-compose reads `.env` automatically.
# `.env` is gitignored; this example file is committed.

# --- Upstream BlueMap server (the proxy fetches tiles from this origin) ---
# Must be reachable from the host running docker. No path; just origin.
BLUEMAP_BASE_URL=http://your-bluemap-host:8100
# The map id BlueMap exposes under /maps/<id>. Usually your overworld dim id.
BLUEMAP_MAP_ID=world
# Tile cache dir inside the container. No need to change.
BLUEMAP_CACHE_DIR=/cache
# Per-request timeout when proxying to BlueMap.
BLUEMAP_TIMEOUT_SECONDS=10

# --- Client-side values baked into served .lua files ---
# Public URL the CC computers use to reach this service (must be in CC:T's
# http whitelist on the Minecraft server). Include scheme and port.
CLIENT_SERVER_URL=http://your-public-host:5055
# Your Minecraft username; used to skip drawing your own player dot on the
# minimap (the ship triangle marker is already drawn at the same position).
# Leave blank if you want your own marker shown, or for multi-user installs
# (each CC can override via `playerName` in its local minimap.cfg).
CLIENT_PLAYER_NAME=
